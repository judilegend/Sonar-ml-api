# ── ML Model (generated by ml/train.py) ───────────────────────
# Never commit the .pkl model — it can weigh several MB
# and is automatically regenerated by the CI/CD pipeline
models/

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd

# ── Virtual Environment ───────────────────────────────────────
# If you use venv or conda locally
venv/
env/
.env/
.venv/

# ── Environment Variables ─────────────────────────────────────
# Contains secrets (passwords, API keys) — NEVER on Git
.env
.env.local
.env.production

# ── Tests and Coverage ────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Python Build ──────────────────────────────────────────────
dist/
build/
*.egg-info/

# ── Docker ────────────────────────────────────────────────────
# Local Docker logs if generated
*.log

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.DS_Store        # macOS